{"html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\"/>\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1.0\"/>\n<title>SafeWalk \u2014 Live Map</title>\n<link rel=\"stylesheet\" href=\"https://unpkg.com/leaflet@1.9.4/dist/leaflet.css\"/>\n<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap\" rel=\"stylesheet\">\n<style>\n:root {\n  --red:#E53935; --red2:#EF5350; --red-bg:rgba(229,57,53,.09);\n  --safe:#0D9E5C; --mod:#D97706; --caut:#DC4E12; --dng:#C41717;\n  --white:#fff; --bg:#F8F9FA; --surface:#fff;\n  --border:#E8EAED; --border2:#DADCE0;\n  --text:#202124; --text2:#5F6368; --text3:#9AA0A6;\n  --font:'Inter',-apple-system,sans-serif;\n  --sh:0 2px 10px rgba(32,33,36,.15); --sh2:0 4px 24px rgba(32,33,36,.18);\n  --panel-radius:16px;\n}\n*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }\nhtml, body { height: 100%; font-family: var(--font); overflow: hidden; background: var(--bg); }\n#map { position: fixed; inset: 0; z-index: 1; }\n\n/* \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\n   TOP BAR  \u2014 exactly like Google Maps\n   \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550 */\n.topbar {\n  position: fixed; top: 0; left: 0; right: 0; z-index: 1000;\n  padding: 10px 12px;\n  display: flex; align-items: center; gap: 10px;\n  pointer-events: none;\n}\n.topbar > * { pointer-events: auto; }\n\n.logo-btn {\n  background: var(--white); border: none; border-radius: 12px;\n  padding: 0 14px; height: 46px;\n  font-family: var(--font); font-size: 15px; font-weight: 700;\n  color: var(--red); cursor: pointer; flex-shrink: 0;\n  box-shadow: var(--sh); display: flex; align-items: center; gap: 6px;\n  letter-spacing: -.3px;\n}\n\n/* Google-style search bar */\n.search-wrap { flex: 1; max-width: 500px; position: relative; }\n.search-input {\n  width: 100%; height: 46px;\n  background: var(--white); border: none;\n  border-radius: 24px;\n  padding: 0 16px 0 48px;\n  font-size: 14px; font-family: var(--font); color: var(--text);\n  outline: none; box-shadow: var(--sh);\n  transition: box-shadow .2s;\n}\n.search-input:focus { box-shadow: var(--sh2); }\n.search-input::placeholder { color: var(--text3); }\n.search-ico {\n  position: absolute; left: 16px; top: 50%; transform: translateY(-50%);\n  color: var(--text3); font-size: 17px; pointer-events: none;\n}\n.search-clear {\n  position: absolute; right: 14px; top: 50%; transform: translateY(-50%);\n  background: none; border: none; cursor: pointer; color: var(--text3);\n  font-size: 18px; display: none; line-height: 1;\n}\n.search-input:not(:placeholder-shown) ~ .search-clear { display: block; }\n.search-dropdown {\n  position: absolute; top: 54px; left: 0; right: 0;\n  background: var(--white); border-radius: 16px;\n  overflow: hidden; box-shadow: var(--sh2); display: none; z-index: 200;\n}\n.search-dropdown.open { display: block; }\n.sresult {\n  padding: 12px 16px; cursor: pointer; display: flex; align-items: center; gap: 12px;\n  border-bottom: 1px solid var(--border); transition: background .12s;\n}\n.sresult:last-child { border-bottom: none; }\n.sresult:hover { background: var(--bg); }\n.sresult-ico {\n  width: 36px; height: 36px; border-radius: 50%; background: var(--bg);\n  display: flex; align-items: center; justify-content: center;\n  font-size: 16px; flex-shrink: 0;\n}\n.sresult-name { font-size: 14px; font-weight: 500; color: var(--text); }\n.sresult-sub  { font-size: 12px; color: var(--text3); margin-top: 1px; }\n\n.topbar-actions { display: flex; gap: 8px; }\n.map-action-btn {\n  width: 46px; height: 46px; border-radius: 50%;\n  background: var(--white); border: none;\n  box-shadow: var(--sh); cursor: pointer; font-size: 18px;\n  display: flex; align-items: center; justify-content: center;\n  color: var(--text2); transition: all .15s; text-decoration: none;\n}\n.map-action-btn:hover { box-shadow: var(--sh2); color: var(--text); }\n.map-action-btn.active { background: var(--red); color: #fff; }\n.map-action-btn.report-btn { background: var(--red); color: #fff; font-size: 22px; font-weight: 700; }\n\n/* \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\n   ROUTE PANEL\n   \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550 */\n.route-panel {\n  position: fixed; top: 68px; left: 12px;\n  width: 340px;\n  background: var(--white); border-radius: var(--panel-radius);\n  box-shadow: var(--sh2); z-index: 999; display: none; overflow: hidden;\n}\n.route-panel.open { display: block; animation: slidedown .2s ease; }\n@keyframes slidedown { from { opacity: 0; transform: translateY(-8px); } to { opacity: 1; transform: translateY(0); } }\n\n.rp-header {\n  padding: 14px 16px 12px;\n  display: flex; align-items: center; justify-content: space-between;\n  border-bottom: 1px solid var(--border);\n}\n.rp-title { font-size: 14px; font-weight: 600; color: var(--text); }\n.rp-close { background: none; border: none; cursor: pointer; color: var(--text3); font-size: 22px; line-height: 1; transition: color .12s; }\n.rp-close:hover { color: var(--text); }\n\n.rp-inputs { padding: 14px 16px 0; }\n.rp-field { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; }\n.rp-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }\n.rp-dot.from { background: #4285F4; }\n.rp-dot.to   { background: var(--red); }\n.rp-connector { width: 2px; height: 14px; background: var(--border2); margin: -4px 0 -4px 4px; }\n.rp-input {\n  flex: 1; height: 40px;\n  background: var(--bg); border: 1.5px solid var(--border2); border-radius: 10px;\n  padding: 0 12px; font-size: 13px; font-family: var(--font);\n  color: var(--text); outline: none; transition: border-color .15s;\n}\n.rp-input:focus { border-color: #4285F4; background: var(--white); }\n.rp-input::placeholder { color: var(--text3); }\n.rp-gps-btn {\n  width: 36px; height: 36px; border-radius: 50%;\n  background: var(--bg); border: 1.5px solid var(--border2);\n  cursor: pointer; display: flex; align-items: center; justify-content: center;\n  font-size: 15px; color: var(--text2); transition: all .15s; flex-shrink: 0;\n}\n.rp-gps-btn:hover { border-color: #4285F4; color: #4285F4; }\n\n.rp-go-btn {\n  margin: 12px 16px 14px; width: calc(100% - 32px); height: 42px;\n  background: var(--red); color: #fff; border: none; border-radius: 10px;\n  font-size: 14px; font-weight: 600; font-family: var(--font); cursor: pointer;\n  transition: background .15s;\n}\n.rp-go-btn:hover { background: var(--red2); }\n.rp-go-btn:disabled { opacity: .55; cursor: not-allowed; }\n\n.rp-result { border-top: 1px solid var(--border); padding: 12px 16px; display: none; }\n.rp-result.open { display: block; }\n.rp-verdict {\n  display: flex; align-items: center; justify-content: space-between;\n  padding: 10px 12px; border-radius: 10px; margin-bottom: 10px;\n  font-size: 13px; font-weight: 600;\n}\n.rp-steps { display: flex; flex-direction: column; gap: 4px; max-height: 220px; overflow-y: auto; }\n.rp-step {\n  display: flex; align-items: center; gap: 10px;\n  padding: 8px 10px; background: var(--bg); border-radius: 9px; font-size: 12px;\n}\n.rp-step-n {\n  width: 22px; height: 22px; border-radius: 50%; background: var(--border2);\n  display: flex; align-items: center; justify-content: center;\n  font-size: 10px; font-weight: 700; color: var(--text2); flex-shrink: 0;\n}\n.rp-step-txt { flex: 1; color: var(--text2); line-height: 1.4; }\n.rp-step-dist { font-size: 11px; color: var(--text3); font-weight: 500; white-space: nowrap; }\n.rp-danger-zones { margin-top: 10px; }\n.rp-dz-title { font-size: 11px; font-weight: 600; color: var(--text3); text-transform: uppercase; letter-spacing: .05em; margin-bottom: 6px; }\n.rp-dz-item {\n  display: flex; justify-content: space-between; align-items: center;\n  padding: 7px 10px; background: rgba(229,57,53,.05); border-radius: 8px;\n  margin-bottom: 4px; font-size: 12px; border: 1px solid rgba(229,57,53,.12);\n}\n\n/* \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\n   STREET INFO PANEL (bottom)\n   \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550 */\n.street-panel {\n  position: fixed; bottom: 16px; left: 50%; transform: translateX(-50%);\n  width: 400px; max-width: calc(100vw - 24px);\n  background: var(--white); border-radius: 20px;\n  box-shadow: var(--sh2); z-index: 1000; display: none; overflow: hidden;\n}\n.street-panel.open { display: block; animation: slideup .22s ease; }\n@keyframes slideup {\n  from { opacity: 0; transform: translateX(-50%) translateY(16px); }\n  to   { opacity: 1; transform: translateX(-50%) translateY(0); }\n}\n.sp-drag { width: 32px; height: 4px; background: var(--border2); border-radius: 2px; margin: 10px auto 0; }\n.sp-body { padding: 12px 18px 18px; }\n.sp-row1 { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 10px; }\n.sp-name { font-size: 16px; font-weight: 600; color: var(--text); flex: 1; padding-right: 8px; line-height: 1.3; }\n.sp-x { background: none; border: none; cursor: pointer; color: var(--text3); font-size: 22px; line-height: 1; }\n.sp-x:hover { color: var(--text); }\n.sp-escalated {\n  background: #FFF8E1; border: 1px solid #FFD600; border-radius: 8px;\n  padding: 8px 12px; font-size: 12px; color: #795500;\n  display: flex; align-items: center; gap: 6px; margin-bottom: 10px;\n}\n.sp-score-row { display: flex; align-items: center; gap: 16px; margin-bottom: 14px; }\n.sp-score-num { font-size: 52px; font-weight: 700; line-height: 1; font-variant-numeric: tabular-nums; }\n.sp-score-info { flex: 1; }\n.sp-score-lbl { font-size: 15px; font-weight: 600; }\n.sp-score-sub { font-size: 12px; color: var(--text3); margin-top: 2px; }\n.sp-trend {\n  display: inline-flex; align-items: center; gap: 4px;\n  margin-top: 6px; padding: 3px 10px; border-radius: 20px;\n  font-size: 11px; font-weight: 600;\n}\n.t-up   { background: rgba(13,158,92,.1);  color: #0D9E5C; }\n.t-down { background: rgba(229,57,53,.1);  color: #E53935; }\n.t-stab { background: var(--bg);           color: var(--text3); }\n.sp-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; margin-bottom: 14px; }\n.sp-cell { background: var(--bg); border-radius: 10px; padding: 10px; text-align: center; border: 1px solid var(--border); }\n.sp-cell-val { font-size: 18px; font-weight: 700; color: var(--text); }\n.sp-cell-lbl { font-size: 10px; color: var(--text3); text-transform: uppercase; letter-spacing: .04em; margin-top: 2px; }\n.sp-actions { display: flex; gap: 8px; }\n.sp-btn {\n  flex: 1; height: 40px; border-radius: 10px; font-size: 13px; font-weight: 600;\n  font-family: var(--font); cursor: pointer; border: none; transition: all .15s;\n}\n.sp-btn.primary { background: var(--red); color: #fff; }\n.sp-btn.primary:hover { background: var(--red2); }\n.sp-btn.secondary { background: var(--bg); color: var(--text); border: 1.5px solid var(--border2); }\n.sp-btn.secondary:hover { border-color: #4285F4; color: #4285F4; }\n\n/* \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\n   PROFILE PANEL\n   \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550 */\n.profile-panel {\n  position: fixed; top: 68px; right: 12px; width: 310px;\n  background: var(--white); border-radius: var(--panel-radius);\n  box-shadow: var(--sh2); z-index: 999; display: none; overflow: hidden;\n}\n.profile-panel.open { display: block; animation: slidedown .2s ease; }\n.pp-user { display: flex; align-items: center; gap: 12px; padding: 14px 16px; border-bottom: 1px solid var(--border); }\n.pp-avatar { width: 42px; height: 42px; border-radius: 50%; background: var(--red); display: flex; align-items: center; justify-content: center; font-size: 16px; font-weight: 700; color: #fff; flex-shrink: 0; }\n.pp-name  { font-size: 14px; font-weight: 600; color: var(--text); }\n.pp-email { font-size: 12px; color: var(--text3); }\n.pp-body  { padding: 12px 16px; }\n.pp-section-title { font-size: 11px; font-weight: 600; color: var(--text3); text-transform: uppercase; letter-spacing: .06em; margin-bottom: 10px; }\n.contact-chip {\n  display: flex; align-items: center; justify-content: space-between;\n  padding: 9px 12px; background: var(--bg); border-radius: 9px;\n  margin-bottom: 6px; border: 1px solid var(--border);\n}\n.cc-name  { font-size: 13px; font-weight: 500; color: var(--text); }\n.cc-phone { font-size: 11px; color: var(--text3); margin-top: 1px; }\n.cc-rm    { background: none; border: none; cursor: pointer; color: var(--text3); font-size: 16px; transition: color .12s; }\n.cc-rm:hover { color: var(--red); }\n.add-contact-wrap { display: none; padding: 12px; background: var(--bg); border-radius: 10px; border: 1px solid var(--border); margin-top: 8px; }\n.add-contact-wrap.open { display: block; }\n.ac-input { width: 100%; padding: 8px 10px; background: var(--white); border: 1.5px solid var(--border2); border-radius: 8px; font-size: 12px; font-family: var(--font); color: var(--text); outline: none; margin-bottom: 6px; }\n.ac-input:focus { border-color: #4285F4; }\n.ac-input::placeholder { color: var(--text3); }\n.ac-btns { display: flex; gap: 6px; }\n.ac-btn { padding: 7px 14px; border-radius: 7px; font-size: 12px; font-weight: 600; font-family: var(--font); cursor: pointer; border: none; transition: all .15s; }\n.ac-btn.save { background: var(--red); color: #fff; }\n.ac-btn.cancel { background: var(--bg); color: var(--text2); border: 1px solid var(--border2); }\n.add-contact-trigger {\n  width: 100%; padding: 9px; background: var(--white); border: 1.5px dashed var(--border2);\n  border-radius: 9px; color: var(--text2); font-size: 13px; cursor: pointer;\n  margin-top: 8px; font-family: var(--font); transition: all .15s;\n}\n.add-contact-trigger:hover { border-color: #4285F4; color: #4285F4; }\n.pp-divider { height: 1px; background: var(--border); margin: 12px 0; }\n.pp-action {\n  display: flex; align-items: center; gap: 10px;\n  padding: 10px 12px; border-radius: 9px;\n  font-size: 13px; color: var(--text); cursor: pointer;\n  border: none; background: none; width: 100%; text-decoration: none;\n  font-family: var(--font); transition: background .12s;\n}\n.pp-action:hover { background: var(--bg); }\n.pp-action.red { color: var(--red); }\n\n/* \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\n   MAP CONTROLS (right side)\n   \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550 */\n.map-controls {\n  position: fixed; right: 12px; bottom: 160px;\n  display: flex; flex-direction: column; gap: 2px; z-index: 999;\n}\n.mc-btn {\n  width: 40px; height: 40px;\n  background: var(--white); border: none;\n  box-shadow: var(--sh); cursor: pointer;\n  font-size: 18px; display: flex; align-items: center; justify-content: center;\n  color: var(--text2); transition: all .15s;\n}\n.mc-btn:first-child { border-radius: 8px 8px 0 0; border-bottom: 1px solid var(--border); }\n.mc-btn:last-child  { border-radius: 0 0 8px 8px; }\n.mc-btn:hover { color: var(--text); }\n.mc-locate {\n  width: 40px; height: 40px; border-radius: 50%;\n  background: var(--white); border: none;\n  box-shadow: var(--sh); cursor: pointer; font-size: 17px;\n  display: flex; align-items: center; justify-content: center;\n  color: var(--text2); margin-top: 8px; transition: all .15s;\n}\n.mc-locate:hover { box-shadow: var(--sh2); color: #4285F4; }\n\n/* \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\n   LEGEND\n   \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550 */\n.legend {\n  position: fixed; bottom: 16px; right: 12px;\n  background: var(--white); border-radius: 12px;\n  box-shadow: var(--sh); padding: 12px 14px; z-index: 999;\n}\n.leg-title { font-size: 11px; font-weight: 600; color: var(--text2); text-transform: uppercase; letter-spacing: .05em; margin-bottom: 8px; }\n.leg-row   { display: flex; align-items: center; gap: 8px; margin-bottom: 5px; font-size: 12px; color: var(--text2); }\n.leg-row:last-child { margin-bottom: 0; }\n.leg-dot   { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }\n\n/* \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\n   SOS BUTTON\n   \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550 */\n.sos-btn {\n  position: fixed; bottom: 16px; left: 16px;\n  width: 60px; height: 60px; border-radius: 50%;\n  background: var(--red); color: #fff; font-size: 13px; font-weight: 800;\n  border: 3px solid #fff; cursor: pointer; z-index: 1001;\n  box-shadow: 0 4px 20px rgba(229,57,53,.5);\n  animation: sos-pulse 2.5s ease-in-out infinite;\n  transition: transform .15s; font-family: var(--font);\n}\n.sos-btn:hover   { transform: scale(1.06); }\n.sos-btn:active  { transform: scale(.95); }\n@keyframes sos-pulse {\n  0%,100% { box-shadow: 0 4px 20px rgba(229,57,53,.5); }\n  50%     { box-shadow: 0 4px 30px rgba(229,57,53,.9), 0 0 0 8px rgba(229,57,53,.12); }\n}\n\n/* \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\n   NIGHT BANNER\n   \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550 */\n.night-banner {\n  position: fixed; top: 68px; left: 50%; transform: translateX(-50%);\n  background: #1a1a2e; color: #a0a0d0; padding: 6px 18px;\n  border-radius: 20px; font-size: 12px; z-index: 998; display: none;\n}\n\n/* \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\n   LOADING\n   \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550 */\n.loader {\n  position: fixed; inset: 0; background: var(--white); z-index: 3000;\n  display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 14px;\n}\n.loader-ring { width: 40px; height: 40px; border: 3px solid var(--border); border-top-color: var(--red); border-radius: 50%; animation: spin .65s linear infinite; }\n@keyframes spin { to { transform: rotate(360deg); } }\n.loader-text { font-size: 14px; color: var(--text2); font-weight: 500; }\n\n/* \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\n   TOAST\n   \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550 */\n.toast {\n  position: fixed; bottom: 90px; left: 50%; transform: translateX(-50%) translateY(12px);\n  padding: 10px 20px; border-radius: 10px; font-size: 13px; font-weight: 500;\n  z-index: 4000; opacity: 0; transition: all .22s; pointer-events: none;\n  white-space: nowrap; box-shadow: var(--sh2); background: #1f2937; color: #fff;\n}\n.toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }\n.toast.ok   { background: var(--safe); }\n.toast.err  { background: var(--red); }\n\n/* \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\n   USER LOCATION DOT\n   \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550 */\n.user-dot { width: 14px; height: 14px; border-radius: 50%; background: #4285F4; border: 2.5px solid #fff; box-shadow: 0 0 0 4px rgba(66,133,244,.22); animation: udot 2s ease-in-out infinite; }\n@keyframes udot { 0%,100% { box-shadow: 0 0 0 4px rgba(66,133,244,.2); } 50% { box-shadow: 0 0 0 9px rgba(66,133,244,.06); } }\n\n/* \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\n   LEAFLET OVERRIDES\n   \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550 */\n.leaflet-control-zoom { display: none !important; }\n.leaflet-control-attribution { font-size: 10px !important; }\n.leaflet-popup-content-wrapper {\n  border-radius: 14px !important;\n  box-shadow: var(--sh2) !important;\n  padding: 0 !important;\n  border: 1px solid var(--border) !important;\n}\n.leaflet-popup-content { margin: 0 !important; }\n.leaflet-popup-tip-container { display: none !important; }\n.leaflet-popup-close-button { display: none !important; }\n.leaflet-tooltip {\n  background: var(--white) !important; border: 1px solid var(--border2) !important;\n  border-radius: 8px !important; font-family: var(--font) !important;\n  box-shadow: var(--sh) !important; padding: 6px 10px !important; font-size: 12px !important;\n}\n.leaflet-tooltip::before { display: none !important; }\n\n@media (max-width: 600px) {\n  .search-wrap { max-width: 100%; }\n  .topbar { flex-wrap: wrap; }\n  .legend { display: none; }\n  .route-panel { width: calc(100vw - 24px); }\n  .profile-panel { width: calc(100vw - 24px); right: 12px; }\n}\n</style>\n</head>\n<body>\n\n<div id=\"map\"></div>\n\n<div class=\"loader\" id=\"loader\">\n  <div class=\"loader-ring\"></div>\n  <div class=\"loader-text\">Loading SafeWalk...</div>\n</div>\n\n<div class=\"night-banner\" id=\"nightBanner\">Night mode \u2014 safety scores weighted higher</div>\n\n<!-- \u2500\u2500 TOP BAR \u2500\u2500 -->\n<div class=\"topbar\">\n  <button class=\"logo-btn\">\n    <span style=\"color:var(--red);\">&#128205;</span> SafeWalk\n  </button>\n\n  <div class=\"search-wrap\">\n    <span class=\"search-ico\">&#128269;</span>\n    <input class=\"search-input\" id=\"searchInput\" type=\"text\"\n           placeholder=\"Search any street, lane or area...\" autocomplete=\"off\"/>\n    <button class=\"search-clear\" onclick=\"clearSearch()\">&#215;</button>\n    <div class=\"search-dropdown\" id=\"searchDrop\"></div>\n  </div>\n\n  <div class=\"topbar-actions\">\n    <button class=\"map-action-btn\" id=\"routeBtn\" onclick=\"toggleRoute()\" title=\"Plan safe route\">&#128739;</button>\n    <button class=\"map-action-btn\" onclick=\"locateMe()\" title=\"My location\">&#9678;</button>\n    <a href=\"report.html\" class=\"map-action-btn report-btn\" title=\"Report incident\">&#43;</a>\n    <button class=\"map-action-btn\" id=\"profileBtn\" onclick=\"toggleProfile()\" title=\"My profile\">&#128100;</button>\n  </div>\n</div>\n\n<!-- \u2500\u2500 ROUTE PANEL \u2500\u2500 -->\n<div class=\"route-panel\" id=\"routePanel\">\n  <div class=\"rp-header\">\n    <span class=\"rp-title\">&#128739; Plan Safe Route</span>\n    <button class=\"rp-close\" onclick=\"toggleRoute()\">&#215;</button>\n  </div>\n  <div class=\"rp-inputs\">\n    <div class=\"rp-field\">\n      <div class=\"rp-dot from\"></div>\n      <input class=\"rp-input\" id=\"rpFrom\" placeholder=\"Starting point\" type=\"text\"/>\n      <button class=\"rp-gps-btn\" onclick=\"fillGPS('from')\" title=\"Use my location\">&#9678;</button>\n    </div>\n    <div class=\"rp-connector\" style=\"margin-left:15px;\"></div>\n    <div class=\"rp-field\">\n      <div class=\"rp-dot to\"></div>\n      <input class=\"rp-input\" id=\"rpTo\" placeholder=\"Where are you going?\" type=\"text\"/>\n      <button class=\"rp-gps-btn\" onclick=\"fillGPS('to')\" title=\"Use my location\">&#9678;</button>\n    </div>\n  </div>\n  <button class=\"rp-go-btn\" id=\"rpGoBtn\" onclick=\"planRoute()\">Get Safe Route</button>\n  <div class=\"rp-result\" id=\"rpResult\">\n    <div class=\"rp-verdict\" id=\"rpVerdict\"></div>\n    <div class=\"rp-steps\"  id=\"rpSteps\"></div>\n    <div class=\"rp-danger-zones\" id=\"rpDangerZones\"></div>\n  </div>\n</div>\n\n<!-- \u2500\u2500 STREET INFO PANEL \u2500\u2500 -->\n<div class=\"street-panel\" id=\"streetPanel\">\n  <div class=\"sp-drag\"></div>\n  <div class=\"sp-body\">\n    <div class=\"sp-row1\">\n      <div class=\"sp-name\" id=\"spName\"></div>\n      <button class=\"sp-x\" onclick=\"closeSP()\">&#215;</button>\n    </div>\n    <div class=\"sp-escalated\" id=\"spEscalated\" style=\"display:none;\">\n      &#9888; This zone has been flagged and escalated to authorities\n    </div>\n    <div class=\"sp-score-row\">\n      <div class=\"sp-score-num\" id=\"spNum\"></div>\n      <div class=\"sp-score-info\">\n        <div class=\"sp-score-lbl\" id=\"spLbl\"></div>\n        <div class=\"sp-score-sub\">out of 100</div>\n        <span class=\"sp-trend\" id=\"spTrend\"></span>\n      </div>\n    </div>\n    <div class=\"sp-grid\">\n      <div class=\"sp-cell\">\n        <div class=\"sp-cell-val\" id=\"spDay\"></div>\n        <div class=\"sp-cell-lbl\">Day</div>\n      </div>\n      <div class=\"sp-cell\">\n        <div class=\"sp-cell-val\" id=\"spNight\"></div>\n        <div class=\"sp-cell-lbl\">Night</div>\n      </div>\n      <div class=\"sp-cell\">\n        <div class=\"sp-cell-val\" id=\"spReports\"></div>\n        <div class=\"sp-cell-lbl\">Reports</div>\n      </div>\n    </div>\n    <div class=\"sp-actions\">\n      <button class=\"sp-btn primary\" id=\"spRepBtn\">Report here</button>\n      <button class=\"sp-btn secondary\" onclick=\"routeToHere()\">Route here</button>\n    </div>\n  </div>\n</div>\n\n<!-- \u2500\u2500 PROFILE PANEL \u2500\u2500 -->\n<div class=\"profile-panel\" id=\"profilePanel\">\n  <div class=\"pp-user\">\n    <div class=\"pp-avatar\" id=\"ppInitial\">?</div>\n    <div>\n      <div class=\"pp-name\"  id=\"ppName\">Loading...</div>\n      <div class=\"pp-email\" id=\"ppEmail\"></div>\n    </div>\n  </div>\n  <div class=\"pp-body\">\n    <div class=\"pp-section-title\">SOS Emergency Contacts</div>\n    <div id=\"ppContactList\"></div>\n    <button class=\"add-contact-trigger\" onclick=\"toggleAddContact()\">+ Add emergency contact</button>\n    <div class=\"add-contact-wrap\" id=\"addContactWrap\">\n      <input class=\"ac-input\" id=\"acName\"  placeholder=\"Contact name\"/>\n      <input class=\"ac-input\" id=\"acPhone\" placeholder=\"Phone number\"/>\n      <input class=\"ac-input\" id=\"acEmail\" placeholder=\"Email address (gets SOS alert)\"/>\n      <div class=\"ac-btns\">\n        <button class=\"ac-btn save\"   onclick=\"saveContact()\">Save</button>\n        <button class=\"ac-btn cancel\" onclick=\"toggleAddContact()\">Cancel</button>\n      </div>\n    </div>\n    <div class=\"pp-divider\"></div>\n    <a href=\"report.html\" class=\"pp-action\">&#128466; Report an incident</a>\n    <button class=\"pp-action red\" onclick=\"doLogout()\" style=\"width:100%;text-align:left;\">&#128682; Sign out</button>\n  </div>\n</div>\n\n<!-- \u2500\u2500 MAP CONTROLS \u2500\u2500 -->\n<div class=\"map-controls\">\n  <button class=\"mc-btn\" onclick=\"map.zoomIn()\">&#43;</button>\n  <button class=\"mc-btn\" onclick=\"map.zoomOut()\">&#8722;</button>\n  <button class=\"mc-locate\" onclick=\"locateMe()\" title=\"My location\">&#9678;</button>\n</div>\n\n<!-- \u2500\u2500 LEGEND \u2500\u2500 -->\n<div class=\"legend\">\n  <div class=\"leg-title\">Safety Score</div>\n  <div class=\"leg-row\"><span class=\"leg-dot\" style=\"background:#0D9E5C;\"></span>Safe (80\u2013100)</div>\n  <div class=\"leg-row\"><span class=\"leg-dot\" style=\"background:#D97706;\"></span>Moderate (55\u201379)</div>\n  <div class=\"leg-row\"><span class=\"leg-dot\" style=\"background:#DC4E12;\"></span>Caution (30\u201354)</div>\n  <div class=\"leg-row\"><span class=\"leg-dot\" style=\"background:#C41717;\"></span>Danger (0\u201329)</div>\n</div>\n\n<!-- \u2500\u2500 SOS \u2500\u2500 -->\n<button class=\"sos-btn\" id=\"sosBtn\" onclick=\"triggerSOS()\">SOS</button>\n\n<!-- \u2500\u2500 TOAST \u2500\u2500 -->\n<div class=\"toast\" id=\"toast\"></div>\n\n<script src=\"https://unpkg.com/leaflet@1.9.4/dist/leaflet.js\"></script>\n<script src=\"../js/delhi_roads.js\"></script>\n<script src=\"../js/api.js\"></script>\n<script>\nredirectIfNotAuth();\n\n// \u2500\u2500 STATE \u2500\u2500\nlet map, uMarker, uCircle, circles = [], routeLayers = [];\nlet uLat = null, uLng = null, curStreet = null, searchTimer = null;\nlet userContacts = [];\n\n// Night check\nconst hr = new Date().getHours();\nif (hr >= 21 || hr < 6) document.getElementById('nightBanner').style.display = 'block';\n\n// \u2500\u2500 INIT MAP \u2500\u2500\n// Light tiles: CartoDB Positron \u2014 clean, all streets visible, no access block\nmap = L.map('map', { zoomControl: false }).setView([28.6139, 77.2090], 11);\n\nL.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {\n  attribution: '&copy; <a href=\"https://www.openstreetmap.org/copyright\">OpenStreetMap</a> &copy; <a href=\"https://carto.com/attributions\">CARTO</a>',\n  subdomains: 'abcd',\n  maxZoom: 21\n}).addTo(map);\n\nmap.on('click', () => { closeSP(); closeAllPanels(); });\n\n// \u2500\u2500 HELPERS \u2500\u2500\nfunction col(s) { return s>=80?'#0D9E5C':s>=55?'#D97706':s>=30?'#DC4E12':'#C41717'; }\nfunction lbl(s) { return s>=80?'Very Safe':s>=55?'Moderate':s>=30?'Caution':'Danger Zone'; }\nfunction colBg(s){ return s>=80?'rgba(13,158,92,.1)':s>=55?'rgba(217,119,6,.1)':s>=30?'rgba(220,78,18,.1)':'rgba(196,23,23,.1)'; }\n\nfunction toast(msg, type = '') {\n  const t = document.getElementById('toast');\n  t.textContent = msg;\n  t.className = 'toast show' + (type ? ' ' + type : '');\n  clearTimeout(t._t);\n  t._t = setTimeout(() => t.classList.remove('show'), 3200);\n}\n\nfunction closeAllPanels() {\n  document.getElementById('profilePanel').classList.remove('open');\n}\n\n// \u2500\u2500 LOAD USER \u2500\u2500\nconst user = getUser();\nif (user) {\n  document.getElementById('ppInitial').textContent = (user.name || '?')[0].toUpperCase();\n  document.getElementById('ppName').textContent    = user.name || 'User';\n  document.getElementById('ppEmail').textContent   = user.email || '';\n  loadContacts();\n}\n\nasync function loadContacts() {\n  try {\n    const d = await apiFetch('/auth/me');\n    userContacts = d.user.emergency_contacts || [];\n    renderContacts();\n  } catch(e) {}\n}\n\nfunction renderContacts() {\n  const el = document.getElementById('ppContactList');\n  if (!userContacts.length) {\n    el.innerHTML = '<div style=\"font-size:12px;color:var(--text3);padding:4px 0 8px;\">No emergency contacts yet. Add one so SOS can notify them.</div>';\n    return;\n  }\n  el.innerHTML = userContacts.map((c, i) => `\n    <div class=\"contact-chip\">\n      <div>\n        <div class=\"cc-name\">${c.name}</div>\n        <div class=\"cc-phone\">${c.phone || c.email || ''}</div>\n      </div>\n      <button class=\"cc-rm\" onclick=\"removeContact(${i})\" title=\"Remove\">&#215;</button>\n    </div>`).join('');\n}\n\nfunction toggleAddContact() {\n  document.getElementById('addContactWrap').classList.toggle('open');\n}\n\nasync function saveContact() {\n  const name  = document.getElementById('acName').value.trim();\n  const phone = document.getElementById('acPhone').value.trim();\n  const email = document.getElementById('acEmail').value.trim();\n  if (!name) { toast('Enter contact name', 'err'); return; }\n  if (!phone && !email) { toast('Enter phone or email', 'err'); return; }\n  userContacts.push({ name, phone, email });\n  try {\n    await apiFetch('/auth/emergency-contacts', { method: 'PUT', body: JSON.stringify({ contacts: userContacts }) });\n    renderContacts();\n    document.getElementById('acName').value = '';\n    document.getElementById('acPhone').value = '';\n    document.getElementById('acEmail').value = '';\n    document.getElementById('addContactWrap').classList.remove('open');\n    toast('Contact saved!', 'ok');\n  } catch(e) { toast('Save failed', 'err'); userContacts.pop(); }\n}\n\nasync function removeContact(idx) {\n  userContacts.splice(idx, 1);\n  try {\n    await apiFetch('/auth/emergency-contacts', { method: 'PUT', body: JSON.stringify({ contacts: userContacts }) });\n    renderContacts();\n    toast('Contact removed', 'ok');\n  } catch(e) { toast('Failed', 'err'); }\n}\n\nfunction toggleProfile() {\n  document.getElementById('profilePanel').classList.toggle('open');\n  document.getElementById('routePanel').classList.remove('open');\n  document.getElementById('routeBtn').classList.remove('active');\n}\n\n// \u2500\u2500 LOCATE \u2500\u2500\nfunction locateMe() {\n  if (!navigator.geolocation) { toast('GPS not supported', 'err'); return; }\n  toast('Finding your location...');\n  navigator.geolocation.getCurrentPosition(p => {\n    uLat = p.coords.latitude;\n    uLng = p.coords.longitude;\n    placeUserDot(uLat, uLng, p.coords.accuracy);\n    toast('Location found!', 'ok');\n  }, () => {\n    toast('Location denied \u2014 showing Delhi heatmap', 'err');\n  }, { enableHighAccuracy: true, timeout: 12000 });\n}\n\nfunction placeUserDot(lat, lng, acc) {\n  if (uMarker) uMarker.remove();\n  if (uCircle) uCircle.remove();\n  if (acc && acc < 500) {\n    uCircle = L.circle([lat, lng], { radius: acc, color: '#4285F4', fillColor: '#4285F4', fillOpacity: .06, weight: .8 }).addTo(map);\n  }\n  uMarker = L.marker([lat, lng], {\n    icon: L.divIcon({ className: '', html: '<div class=\"user-dot\"></div>', iconSize: [14,14], iconAnchor: [7,7] })\n  }).addTo(map);\n}\n\n// \u2500\u2500 ROAD NETWORK HEATMAP \u2500\u2500\nlet roadLayer = null;\nlet isNightMode = false;\n\nfunction getTimeMode() {\n  const h = new Date().getHours();\n  return (h >= 20 || h < 6) ? 'night' : 'day';\n}\n\nfunction getScore(props) {\n  return getTimeMode() === 'night' ? (props.score_night || 30) : (props.score_day || 60);\n}\n\nfunction renderRoadNetwork() {\n  if (roadLayer) { map.removeLayer(roadLayer); roadLayer = null; }\n  circles.forEach(c => c.remove()); circles = [];\n\n  const mode = getTimeMode();\n  isNightMode = mode === 'night';\n  console.log(`[SafeWalk] Rendering road network (${mode} mode, ${DELHI_ROAD_NETWORK.features.length} segments)`);\n\n  roadLayer = L.geoJSON(DELHI_ROAD_NETWORK, {\n    style: function(feature) {\n      const score = getScore(feature.properties);\n      return {\n        color: col(score),\n        weight: 7,\n        opacity: 0.82,\n        lineJoin: 'round',\n        lineCap: 'round'\n      };\n    },\n    onEachFeature: function(feature, layer) {\n      const p = feature.properties;\n      const score = getScore(p);\n      const c = col(score);\n\n      layer.bindTooltip(\n        `<div style=\"font-weight:600;color:${c};font-size:13px;\">${score}/100</div>` +\n        `<div style=\"color:#5F6368;font-size:11px;\">${p.name}</div>` +\n        `<div style=\"color:#9AA0A6;font-size:10px;margin-top:2px;\">${isNightMode ? '\ud83c\udf19 Night Score' : '\u2600\ufe0f Day Score'}</div>`,\n        { direction: 'top', sticky: true }\n      );\n\n      layer.on('click', function(e) {\n        L.DomEvent.stopPropagation(e);\n        // Build a street-like object for the panel\n        const coords = feature.geometry.coordinates;\n        const mid = coords[Math.floor(coords.length / 2)];\n        showSP({\n          street_name: p.name,\n          score: score,\n          score_day: p.score_day,\n          score_night: p.score_night,\n          trend: p.trend || 'stable',\n          active_report_count: p.active_report_count || 0,\n          escalated: p.escalated || false,\n          lat: mid[1],\n          lng: mid[0]\n        });\n      });\n    }\n  }).addTo(map);\n\n  document.getElementById('loader').style.display = 'none';\n  console.log('[SafeWalk] Road network rendered successfully!');\n}\n\n// Also try loading API data as supplementary dots (fallback/extra)\nasync function loadAll() {\n  try {\n    renderRoadNetwork();\n  } catch(e) {\n    console.error('[SafeWalk] Road network render failed:', e);\n    toast('Failed to render road network', 'err');\n    document.getElementById('loader').style.display = 'none';\n  }\n}\n\nasync function loadNear(lat, lng) {\n  loadAll();\n}\n\n// \u2500\u2500 STREET PANEL \u2500\u2500\nfunction showSP(s) {\n  curStreet = s;\n  const c = col(s.score);\n  document.getElementById('spName').textContent   = s.street_name;\n  document.getElementById('spNum').textContent    = s.score;\n  document.getElementById('spNum').style.color    = c;\n  document.getElementById('spLbl').textContent    = lbl(s.score);\n  document.getElementById('spLbl').style.color    = c;\n  document.getElementById('spDay').textContent    = s.score_day || s.score;\n  document.getElementById('spNight').textContent  = s.score_night || Math.max(0, s.score - 20);\n  document.getElementById('spReports').textContent= s.active_report_count || 0;\n\n  const tr = s.trend || 'stable';\n  const te = document.getElementById('spTrend');\n  te.textContent = tr === 'improving' ? '\u2191 Improving' : tr === 'worsening' ? '\u2193 Worsening' : '\u2192 Stable';\n  te.className = 'sp-trend ' + (tr === 'improving' ? 't-up' : tr === 'worsening' ? 't-down' : 't-stab');\n\n  document.getElementById('spEscalated').style.display = s.escalated ? 'flex' : 'none';\n  document.getElementById('spRepBtn').onclick = () => {\n    location.href = `report.html?lat=${s.lat}&lng=${s.lng}&street=${encodeURIComponent(s.street_name)}`;\n  };\n\n  const el = document.getElementById('streetPanel');\n  el.style.display = 'block';\n  requestAnimationFrame(() => el.classList.add('open'));\n}\n\nfunction closeSP() {\n  const el = document.getElementById('streetPanel');\n  el.classList.remove('open');\n  setTimeout(() => el.style.display = 'none', 240);\n  curStreet = null;\n}\n\nfunction routeToHere() {\n  if (!curStreet) return;\n  document.getElementById('rpTo').value = curStreet.street_name;\n  if (uLat) document.getElementById('rpFrom').value = 'My Location';\n  closeSP();\n  toggleRoute();\n}\n\n// \u2500\u2500 SEARCH \u2500\u2500\ndocument.getElementById('searchInput').addEventListener('input', function() {\n  clearTimeout(searchTimer);\n  const q = this.value.trim();\n  if (q.length < 3) { document.getElementById('searchDrop').classList.remove('open'); return; }\n  searchTimer = setTimeout(() => doSearch(q), 380);\n});\n\ndocument.addEventListener('click', e => {\n  if (!e.target.closest('.search-wrap')) document.getElementById('searchDrop').classList.remove('open');\n});\n\nfunction clearSearch() {\n  document.getElementById('searchInput').value = '';\n  document.getElementById('searchDrop').classList.remove('open');\n}\n\nasync function doSearch(q) {\n  try {\n    const r = await fetch(\n      `https://nominatim.openstreetmap.org/search?q=${encodeURIComponent(q)}&format=json&limit=6&addressdetails=1`,\n      { headers: { 'Accept-Language': 'en' } }\n    );\n    const data = await r.json();\n    const drop = document.getElementById('searchDrop');\n    if (!data.length) { drop.classList.remove('open'); return; }\n    drop.innerHTML = data.map(r => {\n      const nm  = r.name || r.display_name.split(',')[0];\n      const sub = r.display_name.split(',').slice(1, 3).join(', ').trim();\n      const t   = r.type || r.class;\n      const ico = (t==='road'||t==='residential'||t==='street'||t==='footway'||t==='path'||t==='service') ? '&#128739;' :\n                  (t==='hospital'||t==='clinic') ? '&#127973;' :\n                  (t==='school'||t==='university') ? '&#127979;' : '&#128205;';\n      return `<div class=\"sresult\" onclick=\"goToPlace(${r.lat},${r.lon},'${nm.replace(/'/g,\"\\\\'\")}')\">\n        <div class=\"sresult-ico\">${ico}</div>\n        <div>\n          <div class=\"sresult-name\">${nm}</div>\n          <div class=\"sresult-sub\">${sub}</div>\n        </div>\n      </div>`;\n    }).join('');\n    drop.classList.add('open');\n  } catch(e) {}\n}\n\nfunction goToPlace(lat, lng, name) {\n  map.setView([parseFloat(lat), parseFloat(lng)], 18);\n  document.getElementById('searchInput').value = name;\n  document.getElementById('searchDrop').classList.remove('open');\n  loadNear(lat, lng);\n}\n\n// \u2500\u2500 ROUTE PANEL \u2500\u2500\nfunction toggleRoute() {\n  const p   = document.getElementById('routePanel');\n  const btn = document.getElementById('routeBtn');\n  const open = p.classList.toggle('open');\n  btn.classList.toggle('active', open);\n  document.getElementById('profilePanel').classList.remove('open');\n  if (open && uLat) document.getElementById('rpFrom').value = 'My Location';\n}\n\nfunction fillGPS(target) {\n  if (!navigator.geolocation) { toast('GPS not available', 'err'); return; }\n  navigator.geolocation.getCurrentPosition(p => {\n    uLat = p.coords.latitude; uLng = p.coords.longitude;\n    document.getElementById(target === 'from' ? 'rpFrom' : 'rpTo').value = 'My Location';\n    toast('Location set', 'ok');\n  }, () => toast('Location denied', 'err'));\n}\n\nasync function planRoute() {\n  const fv = document.getElementById('rpFrom').value.trim();\n  const tv = document.getElementById('rpTo').value.trim();\n  if (!fv || !tv) { toast('Enter start and destination', 'err'); return; }\n\n  const btn = document.getElementById('rpGoBtn');\n  btn.textContent = 'Planning...'; btn.disabled = true;\n\n  try {\n    let fLat = uLat, fLng = uLng, tLat, tLng;\n\n    // Geocode FROM\n    if (fv !== 'My Location') {\n      const g = await geocodePlace(fv);\n      if (!g) { toast('Start location not found', 'err'); return; }\n      fLat = g.lat; fLng = g.lng;\n    }\n\n    // Geocode TO\n    const gt = await geocodePlace(tv);\n    if (!gt) { toast('Destination not found', 'err'); return; }\n    tLat = gt.lat; tLng = gt.lng;\n\n    if (!fLat || !tLat) { toast('Cannot get coordinates', 'err'); return; }\n\n    // \u2500\u2500 REAL ROUTING via OSRM (foot profile = walking) \u2500\u2500\n    const osrmUrl = `https://router.project-osrm.org/route/v1/foot/${fLng},${fLat};${tLng},${tLat}?overview=full&geometries=geojson&steps=true`;\n    const osrmRes = await fetch(osrmUrl);\n    const osrmData = await osrmRes.json();\n\n    // Clear old route layers\n    routeLayers.forEach(l => map.removeLayer(l)); routeLayers = [];\n\n    if (!osrmData.routes || !osrmData.routes.length) {\n      toast('No route found', 'err'); return;\n    }\n\n    const route = osrmData.routes[0];\n    const coords = route.geometry.coordinates.map(c => [c[1], c[0]]);\n    const distKm = (route.distance / 1000).toFixed(1);\n    const mins   = Math.ceil(route.duration / 60);\n\n    // Get safety score for this route from our API\n    let verdict = 'moderate', avgScore = 70;\n    let dangerStreets = [];\n    try {\n      const safeData = await apiFetch(`/route?from_lat=${fLat}&from_lng=${fLng}&to_lat=${tLat}&to_lng=${tLng}`);\n      verdict      = safeData.safety_verdict || 'moderate';\n      avgScore     = safeData.avg_score      || 70;\n      dangerStreets= safeData.danger_streets || [];\n    } catch(e) {}\n\n    // Route color based on safety\n    const routeColor = verdict === 'safe' ? '#0D9E5C' : verdict === 'dangerous' ? '#C41717' : '#D97706';\n    const routeLine = L.polyline(coords, {\n      color: routeColor, weight: 5, opacity: 0.85,\n      lineJoin: 'round', lineCap: 'round'\n    }).addTo(map);\n    routeLayers.push(routeLine);\n\n    // Start / end markers\n    const startM = L.circleMarker([fLat, fLng], { radius: 8, color: '#4285F4', fillColor: '#4285F4', fillOpacity: 1, weight: 2.5 }).addTo(map);\n    const endM   = L.circleMarker([tLat, tLng], { radius: 8, color: routeColor, fillColor: routeColor, fillOpacity: 1, weight: 2.5 }).addTo(map);\n    routeLayers.push(startM, endM);\n\n    map.fitBounds(routeLine.getBounds(), { padding: [70, 70] });\n\n    // Show result UI\n    const vColors = { safe: { bg: 'rgba(13,158,92,.1)', color: '#0D9E5C' }, moderate: { bg: 'rgba(217,119,6,.1)', color: '#D97706' }, dangerous: { bg: 'rgba(196,23,23,.1)', color: '#C41717' } };\n    const vLabels = { safe: '\u2713 Route is SAFE', moderate: '\u26a0 Route is MODERATE', dangerous: '\u2715 Route is DANGEROUS' };\n    const vc = vColors[verdict] || vColors.moderate;\n    const ve = document.getElementById('rpVerdict');\n    ve.style.background = vc.bg; ve.style.color = vc.color;\n    ve.innerHTML = `<span>${vLabels[verdict]}</span><span style=\"font-size:12px;font-weight:500;color:var(--text2);margin-left:auto;\">${distKm}km \u00b7 ${mins} min</span>`;\n\n    // Turn-by-turn steps\n    const steps = route.legs?.[0]?.steps || [];\n    document.getElementById('rpSteps').innerHTML = steps.slice(0, 8).map((s, i) => {\n      const d = s.distance > 1000 ? (s.distance / 1000).toFixed(1) + ' km' : Math.round(s.distance) + ' m';\n      const instruction = s.maneuver?.type === 'depart' ? `Start on ${s.name || 'route'}` :\n                          s.maneuver?.type === 'arrive' ? 'Arrive at destination' :\n                          s.maneuver?.type === 'turn'   ? `Turn ${s.maneuver.modifier || ''} onto ${s.name || 'road'}` :\n                          s.name ? `Continue on ${s.name}` : 'Continue';\n      return `<div class=\"rp-step\">\n        <div class=\"rp-step-n\">${i + 1}</div>\n        <div class=\"rp-step-txt\">${instruction}</div>\n        <div class=\"rp-step-dist\">${d}</div>\n      </div>`;\n    }).join('');\n\n    // Danger zones\n    if (dangerStreets.length) {\n      document.getElementById('rpDangerZones').innerHTML =\n        `<div class=\"rp-dz-title\">Streets to watch out for</div>` +\n        dangerStreets.slice(0, 3).map(d => `\n          <div class=\"rp-dz-item\">\n            <span>${d.street_name}</span>\n            <span style=\"font-weight:700;color:#C41717;font-size:12px;\">Score: ${d.score}</span>\n          </div>`).join('');\n    }\n\n    document.getElementById('rpResult').classList.add('open');\n\n  } catch(e) {\n    toast('Route planning failed \u2014 check your connection', 'err');\n    console.error(e);\n  } finally {\n    btn.textContent = 'Get Safe Route'; btn.disabled = false;\n  }\n}\n\n// \u2500\u2500 SOS \u2500\u2500\nasync function triggerSOS() {\n  const btn = document.getElementById('sosBtn');\n  btn.textContent = '...'; btn.disabled = true;\n\n  navigator.geolocation.getCurrentPosition(async p => {\n    try {\n      const res = await apiFetch('/sos', {\n        method: 'POST',\n        body: JSON.stringify({ lat: p.coords.latitude, lng: p.coords.longitude })\n      });\n      const n = res.notified || 0;\n      if (n > 0) {\n        toast(`SOS sent! ${n} emergency contact(s) notified`, 'ok');\n      } else {\n        toast('SOS sent! Open profile to add emergency contacts', 'ok');\n        toggleProfile();\n      }\n    } catch(e) {\n      toast('SOS alert triggered', 'ok');\n    } finally {\n      btn.textContent = 'SOS'; btn.disabled = false;\n    }\n  }, () => {\n    toast('Enable GPS for SOS to work', 'err');\n    btn.textContent = 'SOS'; btn.disabled = false;\n  });\n}\n\nfunction doLogout() { clearSession(); location.href = 'login.html'; }\n\n// \u2500\u2500 START \u2500\u2500\n// Render the full Delhi road network immediately, then try GPS\nloadAll();\nlocateMe();\n\n// Re-render every 30 minutes to catch day/night transition\nsetInterval(() => {\n  const wasNight = isNightMode;\n  const nowNight = getTimeMode() === 'night';\n  if (wasNight !== nowNight) {\n    console.log('[SafeWalk] Time mode changed! Re-rendering...');\n    toast(nowNight ? '\ud83c\udf19 Switching to Night Safety Scores' : '\u2600\ufe0f Switching to Day Safety Scores', 'ok');\n    renderRoadNetwork();\n  }\n}, 60000 * 5);\n</script>\n</body>\n</html>\n"}